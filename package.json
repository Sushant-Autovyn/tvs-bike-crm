{
  "name": "bikecrm",
  "version": "1.0.0",
  "description": "Bike CRM - Full Stack Application",
  "main": "server.js",
  "scripts": {
    "ng": "ng",
    "start": "cd backend && node server.js",
    "start:frontend": "ng serve",
    "build": "npm install && npx ng build --configuration production",
    "build:frontend": "npx ng build --configuration production",
    "build:prod": "npx ng build --configuration production --optimization --aot --output-hashing all",
    "watch": "npx ng build --watch --configuration development",
    "test": "npx ng test",
    "dev": "nodemon server.js"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.8.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@angular/cli": "^21.1.4",
    "@angular/build": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "chart.js": "^4.5.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.1",
    "mongoose": "^9.3.3",
    "pdfkit": "^0.18.0"
  },
  "devDependencies": {
    "jsdom": "^27.1.0",
    "vitest": "^4.0.8",
    "nodemon": "^3.1.14"
  }
}
